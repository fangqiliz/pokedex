# ========== CONFIGURACIÓN DEL SERVIDOR ==========
NODE_ENV=development
PORT=5000

# ========== BASE DE DATOS ==========
# Reemplaza con tu string de conexión de MongoDB
# Para MongoDB local: mongodb://localhost:27017/pokedex
# Para MongoDB Atlas: mongodb+srv://usuario:password@cluster.mongodb.net/pokedex
MONGODB_URI=mongodb://localhost:27017/pokedex

# ========== JWT CONFIGURACIÓN ==========
# Genera una clave secreta fuerte para JWT (mínimo 32 caracteres)
# Puedes usar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_super_secreto_jwt_key_aqui_debe_ser_muy_largo_y_seguro_min_32_chars
JWT_EXPIRE=24h

# ========== FRONTEND ==========
# URL del frontend para CORS (ajusta según tu configuración)
FRONTEND_URL=http://localhost:3000

# ========== CONFIGURACIÓN DE EMAIL (OPCIONAL - PARA FUTURAS FUNCIONALIDADES) ==========
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_app_password

# ========== CONFIGURACIÓN DE UPLOADS (OPCIONAL) ==========
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# ========== CONFIGURACIÓN DE LOGS (OPCIONAL) ==========
LOG_LEVEL=info

# ========== RATE LIMITING ==========
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=5

# ========== CONFIGURACIÓN DE SEGURIDAD ==========
BCRYPT_SALT_ROUNDS=12

# ========== CONFIGURACIÓN DE SESSION (OPCIONAL PARA FUTURO USO) ==========
SESSION_SECRET=tu_session_secret_muy_seguro_aqui