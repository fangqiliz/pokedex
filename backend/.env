# ========== CONFIGURACIÓN DEL SERVIDOR ==========
NODE_ENV=development
PORT=5000

# ========== BASE DE DATOS ==========
# Reemplaza con tu string de conexión de MongoDB
# Para MongoDB local: mongodb://localhost:27017/pokedex
# Para MongoDB Atlas: mongodb+srv://usuario:password@cluster.mongodb.net/pokedex
MONGODB_URI=mongodb://localhost:27017/pokedex

# ========== JWT CONFIGURACIÓN ==========
# Genera una clave secreta fuerte para JWT (mínimo 32 caracteres)
# Puedes usar en tu terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Pega el resultado aquí:
JWT_SECRET=336f7d61061b100bd0fe9052267fa95da5d403239165465406933d65da9f8755afd48283635db75088ac95850aa36828228aab5a4a5ee0eacdd716e64e19aec6
JWT_EXPIRE=24h

# ========== FRONTEND ==========
# URL del frontend para CORS (ajusta según tu configuración)
FRONTEND_URL=http://127.0.0.1:5500

# ========== RATE LIMITING ==========
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=5

# ========== CONFIGURACIÓN DE SEGURIDAD ==========
BCRYPT_SALT_ROUNDS=12
